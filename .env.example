# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_db

# Qdrant Vector Database Configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Frontend API Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000

# Application Settings
LOG_LEVEL=INFO
WORKERS=4

# Host directory mounted into the fastapi container at the SAME path inside.
# This lets the UI accept any host path under $HOST_HOME/... and the backend
# can open it with no translation. Override per-machine when running on
# someone else's home directory.
HOST_HOME=/Users/dmitry.kislov

# Where deduplicated files are moved (host path; visible to backend at the
# same path because of the bind-mount above).
TRASH_DIR=/Users/dmitry.kislov/.photo-gaze-trash

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=7
